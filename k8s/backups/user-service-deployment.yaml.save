apiVersion: apps/v1
kind: Deployment
metadata:
  name: user-service
spec:
  replicas: 1
  selector:
    matchLabels:
      app: user-service
  template:
    metadata:
      labels:
        app: user-service
    spec:
      containers:
        - name: user-service
          image: user-service:latest
          imagePullPolicy: Never
          ports:
            - containerPort: 8081
          env:
            env:
  - name: SPRING_PROFILES_ACTIVE
    value: k8s

  - name: SPRING_DATASOURCE_URL
    value: jdbc:postgresql://user-db:5432/jobportal

  - name: SPRING_DATASOURCE_USERNAME
    value: postgres

  - name: SPRING_DATASOURCE_PASSWORD
    value: postgres
